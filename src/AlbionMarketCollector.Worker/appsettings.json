{
  "AlbionMarketCollector": {
    "CollectorKey": "default",
    "ChannelCapacity": 2048,
    "Capture": {
      "EnableLiveCapture": true,
      "Port": 5056,
      "ListenDevices": [
        "Realtek Gaming GbE Family Controller"
      ],
      "ReplayFixturePath": null,
      "ReplayDelayMilliseconds": 0
    },
    "Persistence": {
      "Provider": "PostgreSql",
      "ConnectionString": null,
      "PostgreSql": {
        "ConnectionString": "Host=localhost;Database=AlbionMC;Username=postgres;Password=mysecretpassword"
      }
    },
    "Debug": {
      "LogRawPayloads": true,
      "LogDecodedMessages": true,
      "DumpCapturedPayloadsPath": null
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "AlbionMarketCollector": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
